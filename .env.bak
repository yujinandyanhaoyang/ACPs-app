# OpenAI API configuration (using Alibaba Cloud DashScope compatible endpoint)
# Replace with your own DashScope API key
OPENAI_API_KEY=sk-61c98510420c4c609a483eb26e35dc45
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1



# Per-agent LLM model routing (Alibaba compatible endpoint)
READING_LLM_MODEL=glm-5
READER_PROFILE_LLM_MODEL=qwen3.5-35b-a3b
RECOMMENDATION_ENGINE_LLM_MODEL=glm-5
PROFILE_EMBED_MODEL=qwen3.5-35b-a3b
REC_RANKING_MODEL=MiniMax-M2.1

# Embedding model configuration
# Local offline embedding model (no API key required)
BOOK_CONTENT_EMBED_MODEL=all-MiniLM-L6-v2
BOOK_CONTENT_EMBED_MODEL_PATH=/root/WORK/all-MiniLM-L6-v2


# Book retrieval dataset path override (optional)
# If not set, services/book_retrieval.py prefers data/processed/goodreads/books_master.jsonl,
# then falls back to data/processed/books_min.jsonl.
BOOK_RETRIEVAL_DATASET_PATH=/root/WORK/DATA/processed/books_master_merged.jsonl

# Discovery service URL
DISCOVERY_BASE_URL=http://localhost:8005

# Reading concierge public base URL for ACS descriptor endpoint generation
READING_CONCIERGE_BASE_URL=http://localhost:8100

# mTLS startup toggle (P7)
AGENT_MTLS_ENABLED=false
# Optional shared cert directory override (if not set, resolve from service config JSON)
AGENT_MTLS_CERT_DIR=


# Verbose logging for live debugging
READING_CONCIERGE_LOG_LEVEL=DEBUG
READER_PROFILE_AGENT_LOG_LEVEL=DEBUG
BOOK_CONTENT_AGENT_LOG_LEVEL=DEBUG
RECOMMENDATION_DECISION_AGENT_LOG_LEVEL=DEBUG
RECOMMENDATION_ENGINE_AGENT_LOG_LEVEL=DEBUG
FEEDBACK_AGENT_LOG_LEVEL=DEBUG
RECOMMENDATION_ENGINE_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DATASET_ROOT=/root/WORK/DATA
CF_ITEM_FACTORS_PATH=/root/WORK/DATA/processed/cf_item_factors.npy
CF_BOOK_INDEX_PATH=/root/WORK/DATA/processed/cf_book_id_index.json
BOOKS_INDEX_PATH=/root/WORK/DATA/processed/books_index.faiss
BOOKS_INDEX_META_PATH=/root/WORK/DATA/processed/books_index_meta.jsonl
FAISS_INDEX_PATH=/root/WORK/DATA/processed/books_index.faiss
FAISS_INDEX_META_PATH=/root/WORK/DATA/processed/books_index_meta.jsonl
READING_DISCOVERY_ENABLED=false
REDIS_URL=redis://localhost:6379/0
