# =============================================================================
# ACPs Personalized Reading Recsys — Environment Configuration
# Copy this file to .env and fill in your actual values.
# Never commit .env to git.
# =============================================================================

# ── LLM API (Alibaba DashScope, OpenAI-compatible endpoint) ──────────────────
OPENAI_API_KEY=your_dashscope_api_key_here
OPENAI_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
# Fallback model used by any agent that does not have a per-agent override below
OPENAI_MODEL=qwen-plus

# ── Per-agent LLM model routing ───────────────────────────────────────────────
# Each agent reads its own env var; override here to change model per agent.
READER_PROFILE_LLM_MODEL=qwen3.5-35b-a3b
RECOMMENDATION_ENGINE_LLM_MODEL=qwen3.5-122b-a10b
READING_LLM_MODEL=qwen3.5-122b-a10b
REC_RANKING_MODEL=MiniMax-M2.1
PROFILE_EMBED_MODEL=qwen3.5-35b-a3b

# ── Embedding model (local, no API key required) ──────────────────────────────
BOOK_CONTENT_EMBED_MODEL=all-MiniLM-L6-v2

# ── Dataset paths ─────────────────────────────────────────────────────────────
# Primary merged dataset (1.37M records). Required.
BOOK_RETRIEVAL_DATASET_PATH=/root/WORK/DATA/processed/books_master_merged.jsonl

# LLM-enriched subset (do not overwrite).
BOOK_ENRICHED_DATASET_PATH=/root/WORK/DATA/processed/books_enriched.jsonl

# ── FAISS vector index paths (built by scripts/build_index.py) ────────────────
FAISS_INDEX_PATH=/root/WORK/DATA/processed/books_index.faiss
FAISS_INDEX_META_PATH=/root/WORK/DATA/processed/books_index_meta.jsonl

# ── Offline book enrichment (used only by scripts/enrich_books.py) ────────────
BOOK_AUGMENTATION_BASE_URL=
BOOK_AUGMENTATION_API_KEY=
BOOK_AUGMENTATION_MODEL=qwen-turbo

# ── Agent IDs ─────────────────────────────────────────────────────────────────
BOOK_CONTENT_AGENT_ID=book_content_agent_001
RECOMMENDATION_ENGINE_AGENT_ID=recommendation_engine_agent_001

# ── Service discovery ─────────────────────────────────────────────────────────
DISCOVERY_BASE_URL=http://localhost:8005
READING_CONCIERGE_BASE_URL=http://localhost:8100

# ── mTLS (disabled by default for local development) ──────────────────────────
AGENT_MTLS_ENABLED=false
AGENT_MTLS_CERT_DIR=
