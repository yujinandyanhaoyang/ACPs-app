# ACPs-app 环境变量配置

# =============================================================================
# DashScope 嵌入 API（推荐配置）
# =============================================================================
# 获取 API Key: https://dashscope.console.aliyun.com/apiKey
# 文档：https://help.aliyun.com/zh/dashscope/developer-reference/text-embedding-api-details

# DashScope API Key（必填，用于语义嵌入）
DASHSCOPE_API_KEY=sk-your-api-key-here

# 嵌入模型（可选，默认 text-embedding-v3）
# 可选值：text-embedding-v3, text-embedding-v2
DASHSCOPE_EMBED_MODEL=text-embedding-v3

# =============================================================================
# OpenAI 兼容 API（可选，用于 LLM 调用）
# =============================================================================
# 如果使用阿里云百炼，设置如下：
# OPENAI_API_KEY=sk-your-api-key
# OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# =============================================================================
# 应用配置
# =============================================================================
# 服务端口
PORT=8100

# 日志级别
LOG_LEVEL=INFO

# 数据目录（可选）
# DATA_DIR=/path/to/data

# =============================================================================
# 说明
# =============================================================================
# 1. 如果未配置 DASHSCOPE_API_KEY，系统将自动降级到 hash-fallback 模式
#    - hash-fallback 不需要 API Key，但语义质量较低
#    - 适合离线环境或测试使用
#
# 2. 推荐配置 DashScope API 以获得最佳语义推荐效果
#    - 成本：约 ¥0.0007 / 1000 tokens
#    - 月度成本估算：¥1-2（正常使用）
#
# 3. 复制此文件为 .env 并填入实际配置：
#    cp .env.example .env
