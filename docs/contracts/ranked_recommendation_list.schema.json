{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ranked_recommendation_list.schema.json",
  "x_contract_version": "v1.0.0",
  "title": "RankedRecommendationListJSON",
  "type": "object",
  "required": ["scenario_policy", "ranking"],
  "properties": {
    "scenario_policy": { "type": "string" },
    "ranking": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "book_id",
          "score_total",
          "score_cf",
          "score_content",
          "score_kg",
          "score_diversity",
          "rank_position",
          "explanation",
          "explanation_evidence_refs"
        ],
        "properties": {
          "book_id": { "type": "string" },
          "title": { "type": "string" },
          "score_total": { "type": "number" },
          "score_cf": { "type": "number" },
          "score_content": { "type": "number" },
          "score_kg": { "type": "number" },
          "score_diversity": { "type": "number" },
          "rank_position": { "type": "integer", "minimum": 1 },
          "scenario_policy": { "type": "string" },
          "explanation": { "type": "string" },
          "explanation_evidence_refs": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}